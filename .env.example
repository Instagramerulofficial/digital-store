# =======================================================
# Digital Store - Environment variables (template)
# =======================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# In production, set these as Vercel Project Environment Variables:
#   Vercel dashboard -> Project -> Settings -> Environment Variables
# Mark all "server-only" / unprefixed vars as Production-only secrets.
# Vars with the NEXT_PUBLIC_ prefix are inlined into the client bundle.
# =======================================================


# ----------------------------------------
# Site
# ----------------------------------------
# DEV  : http://localhost:3000
# PROD : https://your-domain.com   (no trailing slash)
# Used for: Stripe success/cancel URLs, receipt email links,
# Telegram inline-button URLs, sitemap, OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ----------------------------------------
# Supabase   (Dashboard -> Settings -> API)
# ----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Name of the PRIVATE storage bucket that holds product files.
# This bucket MUST stay private; downloads are signed server-side.
SUPABASE_PRODUCTS_BUCKET=products


# ----------------------------------------
# Stripe     (Dashboard -> Developers -> API keys)
# ----------------------------------------
# DEV  : use sk_test_ / pk_test_ keys + a `stripe listen` webhook secret.
# PROD : use sk_live_ / pk_live_ keys + the live webhook endpoint secret.
# IMPORTANT: secret + publishable + webhook secret must all be the same
# mode (all test or all live). The webhook handler logs a warning if a
# mismatch is detected.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# DEV  : printed by `npm run stripe:listen:test`
# PROD : Stripe Dashboard -> Developers -> Webhooks -> <your endpoint>
#        -> "Signing secret"  (it starts with `whsec_`)
STRIPE_WEBHOOK_SECRET=whsec_...


# ----------------------------------------
# Resend     (https://resend.com -> API Keys)
# ----------------------------------------
RESEND_API_KEY=re_...
# DEV  : "Digital Store <onboarding@resend.dev>"  (Resend sandbox sender)
# PROD : a sender on a domain you have verified in Resend
#        e.g. "Digital Store <orders@yourdomain.com>"
EMAIL_FROM="Digital Store <onboarding@resend.dev>"


# ----------------------------------------
# OpenAI     (https://platform.openai.com -> API keys)
# ----------------------------------------
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini


# ----------------------------------------
# Marketing agent — Telegram (optional; leave empty to skip)
# ----------------------------------------
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Numeric chat id (your user id, a group id, or a @channel_username).
TELEGRAM_CHANNEL_ID=


# ----------------------------------------
# Cron     (used by /api/cron/agent on Vercel)
# ----------------------------------------
# Long random string. Vercel automatically sends this in the
# `Authorization: Bearer <CRON_SECRET>` header for cron jobs defined
# in `vercel.json` (only when this env var is set).
CRON_SECRET=


# ----------------------------------------
# Admin
# ----------------------------------------
# Comma-separated list of admin emails that can access /admin.
ADMIN_EMAILS=
