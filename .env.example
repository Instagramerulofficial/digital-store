# =======================================================
# Digital Store - Environment variables
# Copy this file to `.env.local` and fill in the values.
# =======================================================

# ----------------------------------------
# Site
# ----------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------
# Supabase   (Dashboard -> Settings -> API)
# ----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Name of the PRIVATE storage bucket that holds product files
SUPABASE_PRODUCTS_BUCKET=products

# ----------------------------------------
# Stripe     (Dashboard -> Developers -> API keys)
# ----------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Printed by `stripe listen --forward-to localhost:3000/api/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----------------------------------------
# Resend     (https://resend.com -> API Keys)
# ----------------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM="Digital Store <noreply@yourdomain.com>"

# ----------------------------------------
# OpenAI     (https://platform.openai.com -> API keys)
# ----------------------------------------
# Used by the AI product generator (/admin/generate) and the marketing agent.
OPENAI_API_KEY=sk-xxx
# Any chat model with JSON-mode support. gpt-4o-mini is cheap & fast.
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------
# Marketing agent — Telegram channel
# ----------------------------------------
# Create a bot with @BotFather, add it as Admin of your channel,
# then paste the bot token and the @channel_username (or -100... id).
# Leave empty to disable Telegram posting (drafts are still generated).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel_username

# ----------------------------------------
# Cron (GET /api/cron/agent)
# ----------------------------------------
# Random long secret. The cron endpoint requires this in the
# Authorization header: `Bearer ${CRON_SECRET}`.
CRON_SECRET=change-me-to-a-long-random-string

# ----------------------------------------
# Admin
# ----------------------------------------
# Comma-separated list of admin emails that can access /admin
ADMIN_EMAILS=admin@example.com
